{
  "name": "auto2fa",
  "displayName": "Auto2FA SSH Manager",
  "description": "Robust SSH connection manager with 2FA for VSCode Remote-SSH",
  "version": "1.0.0",
  "publisher": "auto2fa",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Remote Development"
  ],
  "keywords": [
    "ssh",
    "2fa",
    "remote",
    "connection",
    "automation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto2fa.showStatus",
        "title": "Show Status",
        "category": "Auto2FA"
      },
      {
        "command": "auto2fa.restartDaemon",
        "title": "Restart Daemon",
        "category": "Auto2FA"
      },
      {
        "command": "auto2fa.reconnectHost",
        "title": "Reconnect Host",
        "category": "Auto2FA"
      },
      {
        "command": "auto2fa.viewLogs",
        "title": "View Logs",
        "category": "Auto2FA"
      }
    ],
    "configuration": {
      "title": "Auto2FA",
      "properties": {
        "auto2fa.socketPath": {
          "type": "string",
          "default": "/tmp/auto2fa_daemon.sock",
          "description": "Path to the Auto2FA daemon Unix socket"
        },
        "auto2fa.logPath": {
          "type": "string",
          "default": "/tmp/auto2fa_daemon.log",
          "description": "Path to the Auto2FA daemon log file"
        },
        "auto2fa.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show connection status in the status bar"
        },
        "auto2fa.refreshInterval": {
          "type": "number",
          "default": 30,
          "description": "Status refresh interval in seconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {}
}
