# Auto2FA Optimized SSH Configuration Template
# Copy this to your ~/.ssh/config and customize for your hosts

# Global settings for all hosts
Host *
    # Security settings
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    
    # Keep connections alive. 15s x 12 = a 180s tolerance window: a network
    # blip (wifi handover, VPN renegotiation, laptop briefly asleep) won't
    # tear the connection — and your work — down. The trade-off of a long
    # window: when the connection is *genuinely* dead the terminal freezes for
    # up to this long before giving up. Kept in sync with the ServerAlive*
    # values in auto2fa/backend.py (_start_master_impl).
    ServerAliveInterval 15
    ServerAliveCountMax 12
    TCPKeepAlive yes
    ConnectTimeout 10

    # Control master settings for Auto2FA
    ControlMaster auto
    ControlPersist 10m
    ControlPath ~/.ssh/auto2fa_control/%h_%p.sock

    # Compression and multiplexing
    Compression yes

# Example host configuration
# Replace with your actual host details
Host myserver
    HostName your-server.example.com
    User your-username
    Port 22
    
    # Auto2FA will manage the control socket
    # The ControlPath above will be used automatically

# Add more hosts as needed
# Host anotherserver
#     HostName another-server.example.com
#     User another-username
#     Port 22
